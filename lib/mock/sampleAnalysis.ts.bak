function buildEmotionSummary(
  emotion: string,
  intensity: number,
  relationship: string,
  conflictType: ConflictType
): string {
  const ack      = ACKNOWLEDGMENT[emotion] ?? "많이 힘드셨겠어요.";
  const sig      = SIGNAL[emotion]?.[conflictType] ?? "";
  const belief   = INNER_BELIEF[emotion]?.[conflictType] ?? "";
  const func     = PSYCH_FUNCTION[emotion] ?? "";
  const judgment = RELATIONAL_JUDGMENT[emotion]?.[conflictType] ?? "";

  const base = [ack, sig, belief, func, judgment].filter(Boolean).join(" ");

  if (intensity >= 8) {
    return base + " 지금 감정의 강도가 매우 높은 상태예요. 이 상태에서 바로 대화를 시작하기보다 먼저 감정을 가라앉힐 시간을 갖는 것을 권해드립니다.";
  }
  return base;
}

// ─── Underlying needs ────────────────────────────────────────────────────────

const EMOTION_NEEDS: Record<string, string[]> = {
  anger:       ["존중", "공정함", "자율성"],
  frustration: ["인정", "진전", "명확한 방향"],
  anxiety:     ["안전감", "예측 가능성", "지지"],
  hurt:        ["연결감", "공감", "신뢰"],
  humiliation: ["존엄성", "존중", "심리적 안전감"],
  sadness:     ["연결감", "신뢰", "소속감"],
  confusion:   ["명확성", "투명성", "정보"],
  overwhelmed: ["지지", "균형", "경계"],
};

function buildNeeds(emotion: string, conflictType: ConflictType) {
  const emotionNeeds = EMOTION_NEEDS[emotion] ?? ["존중", "명확성"];
  const typeExtra: Partial<Record<ConflictType, string>> = {
    power_dynamics: "공정함",
    role_clarity:   "명확한 방향",
    workload:       "균형",
    values:         "진정성",
    communication:  "경청",
  };
  const extra = typeExtra[conflictType];
  const needs =
    extra && !emotionNeeds.includes(extra)
      ? [...emotionNeeds, extra]
      : emotionNeeds;

  return {
    needs,
    summary: `지금 가장 필요한 건 ${needs.slice(0, 2).join(", ")}입니다. 이런 마음은 누구나 느낄 수 있는 자연스러운 바람이에요. 이를 인식하고 표현하는 것이 더 나은 소통의 시작입니다.`,
  };
}

// ─── Situation summary ───────────────────────────────────────────────────────

function buildSituationSummary(
  situation: string,
  relationship: string,
  emotion: string
): string {
  const rel =
    relationship === "manager"
      ? "상사"
      : relationship === "subordinate"
      ? "부하직원"
      : "동료";
  const emotionKo = EMOTION_LABELS_KO[emotion] ?? emotion;
  const snippet =
    situation.length > 120
      ? situation.slice(0, 120).trimEnd() + "…"
      : situation;
  return `${rel}${wa(rel)}의 상황에서 ${emotionKo}${eul(emotionKo)} 느끼신 것 같아요. 아래 내용은 작성해 주신 상황을 바탕으로 정리했어요. "${snippet}"`;
}

// ─── Dialogue suggestion ─────────────────────────────────────────────────────

function buildOpeningStatement(
  relationship: string,
  emotion: string,
  conflictType: ConflictType
): string {
  type RelKey = "manager" | "coworker" | "subordinate";

  // Part 1 — Immediacy: what specifically happened
  const immediacy: Record<ConflictType, string> = {
    power_dynamics: "회의에서 제 작업이 다른 사람들 앞에서 지적됐을 때",
    communication:  "제 말이 응답 없이 넘어갔을 때",
    workload:       "제가 감당하기 어렵다고 느끼는 상황에서 업무가 계속 들어왔을 때",
    role_clarity:   "제가 해야 할 일과 아닌 일의 경계가 명확하지 않다고 느꼈을 때",
    values:         "우리가 이 문제를 다르게 보고 있다는 게 분명해졌을 때",
  };

  // Part 2 — Actual experience: not abstract, not polite
  const experience: Record<string, string> = {
    anger:       "솔직히 많이 화가 났어요",
    frustration: "계속 답답함이 쌓이더라고요",
    anxiety:     "불안한 마음이 많이 들었어요",
    hurt:        "마음이 많이 상했어요",
    humiliation: "굉장히 창피하고 위축됐어요",
    sadness:     "무언가 잃은 것 같은 기분이었어요",
    confusion:   "뭐가 잘못된 건지 정리가 안 됐어요",
    overwhelmed: "더 이상 감당하기 어렵다는 느낌이 왔어요",
  };

  // Part 3 — Relational meaning: how user was positioned (emotion × conflictType)
  const relMeaning: Record<string, Record<ConflictType, string>> = {
    anger: {
      power_dynamics: "그게 저한테는 제가 그 자리에서 발언권을 가진 사람이 아닌 것처럼 느껴졌거든요",
      communication:  "그게 저한테는 제 말이 이 관계에서 들릴 필요가 없는 것으로 처리된 것 같았거든요",
      workload:       "그게 저한테는 제 한계가 협의할 조건이 아닌 것으로 취급된 것 같았거든요",
      role_clarity:   "그게 저한테는 제 역할 경계가 제 동의 없이 넘어도 되는 것으로 취급된 것 같았거든요",
      values:         "그게 저한테는 제 판단 기준이 검토 없이 기각된 것처럼 느껴졌거든요",
    },
    frustration: {
      power_dynamics: "그게 저한테는 제가 이 방식을 바꿀 수 없는 위치에 고정돼 있다는 신호로 느껴졌거든요",
      communication:  "그게 저한테는 제 말이 이 관계에서 실질적으로 반영되지 않는다는 신호로 느껴졌거든요",
      workload:       "그게 저한테는 제가 업무 조율의 당사자가 아니라 할당만 받는 역할처럼 느껴졌거든요",
      role_clarity:   "그게 저한테는 제가 역할을 정하는 데 발언권이 없는 사람처럼 취급되고 있다는 신호로 느껴졌거든요",
      values:         "그게 저한테는 제 방식이 이 관계에서 논의될 수 없는 문제로 취급되고 있다는 신호로 느껴졌거든요",
    },
    anxiety: {
      power_dynamics: "그게 저한테는 제 위치가 언제든 재평가받을 수 있다는 신호로 느껴졌거든요",
      communication:  "그게 저한테는 제가 이 관계에서 어떻게 받아들여지고 있는지 알 수 없다는 신호로 느껴졌거든요",
      workload:       "그게 저한테는 이걸 감당하지 못하는 것이 곧 제 위치에 영향을 줄 수 있다는 신호로 느껴졌거든요",
      role_clarity:   "그게 저한테는 어떤 기준으로 제가 평가받는지 알 수 없다는 신호로 느껴졌거든요",
      values:         "그게 저한테는 제 방식이 수용되지 않을 경우 제 위치가 어떻게 될지 모른다는 신호로 느껴졌거든요",
    },
    hurt: {
      power_dynamics: "그게 저한테는 상대가 저를 배려해야 할 사람으로 여기지 않는다는 신호로 느껴졌거든요",
      communication:  "그게 저한테는 제가 이 사람에게 귀 기울일 가치 있는 존재가 아니라는 신호로 느껴졌거든요",
      workload:       "그게 저한테는 상대가 제 한계를 자신과 무관한 문제로 취급하고 있다는 신호로 느껴졌거든요",
      role_clarity:   "그게 저한테는 제가 경계를 표현해도 상대가 그것을 지킬 필요가 없다고 보는 것 같았거든요",
      values:         "그게 저한테는 제가 중요하게 여기는 것이 상대에게는 배려할 가치가 없는 것으로 취급되고 있다는 신호로 느껴졌거든요",
    },
    humiliation: {
      power_dynamics: "그게 저한테는 제가 그 자리에서 수정받아야 할 존재로 위치된 것처럼 느껴졌거든요",
      communication:  "그게 저한테는 제 말이 다른 사람들 앞에서 부적절한 것으로 처리된 것처럼 느껴졌거든요",
      workload:       "그게 저한테는 제가 역할을 제대로 수행하지 못하는 사람으로 드러날 수 있는 상황이라는 신호로 느껴졌거든요",
      role_clarity:   "그게 저한테는 제가 역할을 잘못 이해하고 있었다는 것이 다른 사람들 앞에서 드러난 것처럼 느껴졌거든요",
      values:         "그게 저한테는 제 방식이 다른 사람들 앞에서 틀린 것으로 처리된 것처럼 느껴졌거든요",
    },
    sadness: {
      power_dynamics: "그게 저한테는 이 관계에서 제가 배려받을 수 있다는 기대가 성립하지 않는다는 신호로 느껴졌거든요",
      communication:  "그게 저한테는 이 사람과 서로 들을 수 있는 관계라는 기대가 성립하지 않는다는 신호로 느껴졌거든요",
      workload:       "그게 저한테는 이 관계에서 공정하게 배려받을 수 있다는 기대가 맞지 않는다는 신호로 느껴졌거든요",
      role_clarity:   "그게 저한테는 역할이 함께 정리될 수 있는 관계라는 기대가 성립하지 않는다는 신호로 느껴졌거든요",
      values:         "그게 저한테는 서로의 방식을 존중할 수 있는 관계라는 기대가 맞지 않는다는 신호로 느껴졌거든요",
    },
    confusion: {
      power_dynamics: "그게 저한테는 어떻게 하면 이 사람의 기대를 충족할 수 있는지 알 수 없게 됐거든요",
      communication:  "그게 저한테는 상대가 어떤 의도로 그렇게 했는지, 그리고 저는 어떻게 받아들여지고 있는지 알 수 없었거든요",
      workload:       "그게 저한테는 어디까지가 정당한 요구인지 그 기준을 파악하기 어렵거든요",
      role_clarity:   "그게 저한테는 제가 해야 할 일의 범위가 어디까지인지 이 관계에서 명확하게 알 수 없거든요",
      values:         "그게 저한테는 상대가 어떤 기준으로 이 상황을 판단하는지, 제 기준과 어디서 충돌하는지 파악이 안 됐거든요",
    },
    overwhelmed: {
      power_dynamics: "그게 저한테는 이 구조 안에서 한계를 표현하거나 거절할 수 있는 위치가 아니라는 신호로 느껴졌거든요",
      communication:  "그게 저한테는 제 상태를 전달해도 이 관계에서 반영될 수 있는지 알 수 없다는 신호로 느껴졌거든요",
      workload:       "그게 저한테는 제가 이 상황을 혼자 감당해야 하는 사람으로 고정돼 있다는 신호로 느껴졌거든요",
      role_clarity:   "그게 저한테는 역할이 어디까지인지 모른 채로 계속 감당해야 하는 것처럼 느껴졌거든요",
      values:         "그게 저한테는 제 방식으로 일하는 것이 이 환경에서 계속 저항을 받는 일이고, 그걸 혼자 감당하고 있다는 신호로 느껴졌거든요",
    },
  };

  // Part 4 — Behavioral request: changes the interaction, not just describes it (conflictType × relationship)
  const request: Record<ConflictType, Record<RelKey, string>> = {
    power_dynamics: {
      manager:     "앞으로는 피드백을 줄 때 다른 사람들이 없는 자리에서 먼저 이야기해주셨으면 해요",
      coworker:    "앞으로는 피드백을 줄 때 나한테 직접 먼저 이야기해줬으면 해요",
      subordinate: "앞으로는 이런 경우에 직접 먼저 이야기해줬으면 해요",
    },
    communication: {
      manager:     "그때 제 말을 어떻게 받아들이셨는지 직접 듣고 싶어요",
      coworker:    "그때 어떻게 받아들였는지 직접 말해줬으면 해요",
      subordinate: "그때 어떻게 받아들였는지 직접 말해줬으면 해요",
    },
    workload: {
      manager:     "지금 제 업무량을 같이 한번 짚어봤으면 해요. 어디서부터 조율할 수 있는지 확인하고 싶어요",
      coworker:    "지금 업무 배분이 어떻게 돼 있는지 같이 확인해보고 싶어요",
      subordinate: "지금 업무 분배가 어떤지 같이 짚어봤으면 해요",
    },
    role_clarity: {
      manager:     "제가 어디까지 맡아야 하는지 명확하게 정해두고 싶어요",
      coworker:    "어디까지가 각자 역할인지 같이 명확하게 정리해보고 싶어요",
      subordinate: "어디까지가 각자 역할인지 같이 한번 정리해봤으면 해요",
    },
    values: {
      manager:     "서로 이 부분을 어떻게 다르게 보고 있는지 직접 확인해보고 싶어요",
      coworker:    "서로 어떻게 다르게 보고 있는지 직접 이야기해보고 싶어요",
      subordinate: "서로 어떻게 다르게 보고 있는지 직접 이야기해봤으면 해요",
    },
  };

  const imm  = immediacy[conflictType];
  const exp  = experience[emotion] ?? "솔직히 많이 힘들었어요";
  const rel  = relMeaning[emotion]?.[conflictType] ?? "그게 저한테는 많이 힘든 신호로 느껴졌거든요";
  const rKey = (relationship as RelKey) in request[conflictType]
    ? (relationship as RelKey)
    : "coworker";
  const req  = request[conflictType][rKey];

  return `"${imm}, ${exp}. ${rel}. ${req}."`;
}

function buildDialogue(
  relationship: string,
  emotion: string,
  conflictType: ConflictType,
  intensity: number
) {
  const openingStatement = buildOpeningStatement(relationship, emotion, conflictType);

  const keyPointsByType: Partial<Record<ConflictType, string[]>> = {
    power_dynamics: [
      "'저는' 또는 '나는'으로 시작해서 그 상황이 내게 어떻게 느껴졌는지 전달하기",
      "피드백의 내용과 전달 방식을 분리해서 이야기하기",
      "앞으로 피드백을 더 건설적으로 나눌 수 있는 방법을 함께 찾아보기",
      "상대방의 의도와 실제 영향이 달랐을 수 있다는 점을 열린 마음으로 이야기하기",
    ],
    communication: [
      "내 입장에서 그 상황이 어떻게 느껴졌는지 담담하게 설명하기",
      "반응하기 전에 상대방이 왜 그랬는지 먼저 물어보기",
      "앞으로는 서로 어떻게 소통하면 좋을지 함께 방향 잡기",
      "사람보다 상황에 초점을 맞춰 이야기하기",
    ],
    workload: [
      "내가 감당할 수 있는 것과 그렇지 않은 것을 구체적으로 이야기하기",
      "단순히 거절하기보다 우선순위를 함께 조율하자고 제안하기",
      "업무량의 문제와 감정적인 부분을 분리해서 이야기하기",
      "실현 가능한 해결책을 제안하거나 함께 찾아보자고 요청하기",
    ],
    role_clarity: [
      "어디서 역할이 겹치거나 불분명하다고 느끼는지 구체적으로 짚어내기",
      "누가 어떤 부분을 책임지는지 명확히 합의하기",
      "개인의 잘못이 아닌 구조적인 문제로 접근하기",
      "합의한 내용을 기록으로 남겨두자고 제안하기",
    ],
    values: [
      "즉각적인 동의를 기대하지 않으며 내 관점을 솔직하게 나누기",
      "상대방의 생각이 어디서 비롯된 건지 진심으로 이해하려 질문하기",
      "차이보다 공통된 목표나 방향을 먼저 확인하기",
      "불편한 부분을 말하기 전에 동의하는 점을 먼저 인정하기",
    ],
  };

  const thingsToAvoidByRelationship: Record<string, string[]> = {
    manager: [
      "다른 사람이 있는 자리나 상대방이 바쁠 때 꺼내기",
      "대화가 아닌 일방적인 불만처럼 들릴 수 있는 방식으로 접근하기",
      "위협적인 표현이나 최후통첩 사용하기",
    ],
    coworker: [
      "일대일로 먼저 이야기하기 전에 다른 사람을 끌어들이기",
      "간접적인 불만 표현이나 회피하는 태도",
      "문제가 더 커질 때까지 방치하기",
    ],
    subordinate: [
      "직위를 내세워 대화를 일방적으로 마무리짓기",
      "상대방 말을 먼저 듣기보다 방어적으로 반응하기",
      "문제를 꺼내는 것 자체를 부담스럽게 만들기",
    ],
  };

  const intensityNote =
    intensity >= 8
      ? "감정이 충분히 가라앉은 뒤에 대화를 시작하세요"
      : "서로 여유 있고 조용한 자리에서 대화하세요";

  return {
    openingStatement,
    keyPoints: [
      intensityNote,
      ...(keyPointsByType[conflictType] ?? keyPointsByType["communication"]!),
    ],
    thingsToAvoid:
      thingsToAvoidByRelationship[relationship] ??
      thingsToAvoidByRelationship["coworker"],
  };
}

// ─── Action guide ────────────────────────────────────────────────────────────

function buildActionGuide(relationship: string, intensity: number) {
  const immediate =
    intensity >= 8
      ? [
          "오늘 당장 대화를 시작하지 않아도 됩니다. 먼저 감정이 가라앉을 시간을 주세요",
          "지금 느끼는 것들을 판단 없이 솔직하게 적어보세요. 자신만을 위한 기록이에요",
          "짧게라도 몸을 움직여 보세요. 산책이나 호흡처럼 자신에게 맞는 방법이면 돼요",
          "마음이 좀 가라앉으면, 정말 하고 싶은 말과 그 이유를 차분히 정리해보세요",
        ]
      : [
          "대화 전에 전하고 싶은 말을 미리 적어두세요",
          "조용하고 편안한 분위기에서 대화할 시간을 잡으세요",
          "목표를 분명히 하세요. 이기는 것이 아니라 서로를 이해하는 것이에요",
        ];

  const longTermByRelationship: Record<string, string[]> = {
    manager: [
      "정기적인 일대일 대화 시간을 만들어두면 갑작스러운 피드백을 줄일 수 있어요",
      "먼저 피드백을 요청하는 습관을 들이면 덜 위협적으로 느껴질 수 있습니다",
      "중요한 대화 후에는 합의한 내용과 기대를 간단히 기록으로 남겨두세요",
    ],
    coworker: [
      "갈등과 무관한 상황에서도 관계에 신경 써보세요. 작은 긍정적인 교류들이 쌓이면 관계가 달라집니다",
      "문제가 커지기 전에 편하게 이야기 나눌 수 있는 분위기를 평소부터 만들어 두세요",
      "서로 균형 있게 느끼는지 가끔 확인해보세요",
    ],
    subordinate: [
      "본인이 먼저 피드백에 열린 태도를 보여주면 상대방도 더 편하게 이야기할 수 있어요",
      "대화 이후에도 업무 관계가 달라지지 않았다는 것을 행동으로 보여주세요",
      "비슷한 문제가 반복되지 않도록 팀 안의 소통 방식을 함께 점검해보세요",
    ],
  };

  return {
    immediate,
    longTerm:
      longTermByRelationship[relationship] ??
      longTermByRelationship["coworker"],
  };
}

// ─── Main generator ──────────────────────────────────────────────────────────

export function generateMockResult(input: ConflictFormValues): ConflictAnalysisResult {
  const { situation, relationship, emotion, intensity } = input;
  const conflict = classifyConflictType(situation);

  return {
    situationSummary: buildSituationSummary(situation, relationship, emotion),
    emotionAnalysis: {
      primary: EMOTION_LABELS_KO[emotion] ?? emotion,
      intensity,
      intensityLabel: intensityLabel(intensity),
      summary: buildEmotionSummary(emotion, intensity, relationship, conflict.type),
    },
    underlyingNeeds: buildNeeds(emotion, conflict.type),
    conflictAnalysis: conflict,
    dialogueSuggestion: buildDialogue(relationship, emotion, conflict.type, intensity),
    actionGuide: buildActionGuide(relationship, intensity),
  };
}
