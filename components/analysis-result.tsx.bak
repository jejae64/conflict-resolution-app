import { ConflictAnalysisResult } from "@/types/conflict";

interface Props {
  result: ConflictAnalysisResult;
  onReset: () => void;
}

const INTENSITY_KO: Record<string, string> = {
  low: "낮음",
  moderate: "보통",
  high: "높음",
  "very high": "매우 높음",
};

export function AnalysisResult({ result, onReset }: Props) {
  return (
    <div className="space-y-4">
      {/* Situation Summary */}
      <Section label="상황 요약">
        <p className="text-sm leading-relaxed text-gray-700">
          {result.situationSummary}
        </p>
      </Section>

      {/* Emotion Analysis */}
      <Section label="감정 분석">
        <div className="flex items-center gap-3 mb-3">
          <span className="rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-800">
            {result.emotionAnalysis.primary}
          </span>
          <span
            className={`text-xs font-medium ${intensityColor(
              result.emotionAnalysis.intensityLabel
            )}`}
          >
            {INTENSITY_KO[result.emotionAnalysis.intensityLabel] ?? result.emotionAnalysis.intensityLabel} &middot;{" "}
            {result.emotionAnalysis.intensity}/10
          </span>
        </div>
        <p className="text-sm leading-relaxed text-gray-700">
          {result.emotionAnalysis.summary}
        </p>
      </Section>

      {/* Underlying Needs */}
      <Section label="근본적인 필요">
        <div className="flex flex-wrap gap-2 mb-3">
          {result.underlyingNeeds.needs.map((need) => (
            <span
              key={need}
              className="rounded-full border border-gray-200 px-3 py-1 text-xs text-gray-600"
            >
              {need}
            </span>
          ))}
        </div>
        <p className="text-sm leading-relaxed text-gray-700">
          {result.underlyingNeeds.summary}
        </p>
      </Section>

      {/* Conflict Type */}
      <Section label="갈등 유형">
        <span className="mb-2 inline-block rounded-full bg-gray-900 px-3 py-1 text-xs font-medium text-white">
          {result.conflictAnalysis.typeLabel}
        </span>
        <p className="text-sm leading-relaxed text-gray-700">
          {result.conflictAnalysis.description}
        </p>
      </Section>

      {/* Suggested Dialogue */}
      <Section label="대화 제안">
        <div className="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3">
          <p className="text-sm italic text-gray-700 leading-relaxed">
            {result.dialogueSuggestion.openingStatement}
          </p>
        </div>
        <SubLabel>전달할 핵심 내용</SubLabel>
        <ul className="mb-4 space-y-1.5">
          {result.dialogueSuggestion.keyPoints.map((pt, i) => (
            <li key={i} className="flex gap-2 text-sm text-gray-700">
              <span className="mt-0.5 text-gray-400">•</span>
              {pt}
            </li>
          ))}
        </ul>
        <SubLabel>피해야 할 것들</SubLabel>
        <ul className="space-y-1.5">
          {result.dialogueSuggestion.thingsToAvoid.map((pt, i) => (
            <li key={i} className="flex gap-2 text-sm text-gray-600">
              <span className="mt-0.5 text-red-300">×</span>
              {pt}
            </li>
          ))}
        </ul>
      </Section>

      {/* Action Guide */}
      <Section label="행동 가이드">
        <SubLabel>대화 전 준비</SubLabel>
        <ul className="mb-4 space-y-1.5">
          {result.actionGuide.immediate.map((step, i) => (
            <li key={i} className="flex gap-2 text-sm text-gray-700">
              <span className="mt-0.5 shrink-0 text-gray-400">{i + 1}.</span>
              {step}
            </li>
          ))}
        </ul>
        <SubLabel>장기적으로</SubLabel>
        <ul className="space-y-1.5">
          {result.actionGuide.longTerm.map((step, i) => (
            <li key={i} className="flex gap-2 text-sm text-gray-700">
              <span className="mt-0.5 shrink-0 text-gray-400">{i + 1}.</span>
              {step}
            </li>
          ))}
        </ul>
      </Section>

      {/* Reset */}
      <button
        onClick={onReset}
        className="w-full rounded-lg border border-gray-200 px-6 py-3 text-sm text-gray-600 transition-colors hover:border-gray-400 hover:text-gray-900"
      >
        다른 상황 분석하기
      </button>
    </div>
  );
}

function Section({
  label,
  children,
}: {
  label: string;
  children: React.ReactNode;
}) {
  return (
    <div className="rounded-lg border border-gray-200 bg-white px-5 py-4">
      <p className="mb-3 text-xs font-semibold uppercase tracking-wider text-gray-400">
        {label}
      </p>
      {children}
    </div>
  );
}

function SubLabel({ children }: { children: React.ReactNode }) {
  return (
    <p className="mb-2 text-xs font-medium text-gray-500">{children}</p>
  );
}

function intensityColor(label: string) {
  if (label === "low") return "text-green-600";
  if (label === "moderate") return "text-yellow-600";
  if (label === "high") return "text-orange-500";
  return "text-red-500";
}
